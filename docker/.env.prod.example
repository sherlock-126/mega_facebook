# Production Environment Configuration
# Copy this file to .env.prod and update with your production values

# Version tag for Docker images
VERSION=latest

# Database Configuration
POSTGRES_USER=mega
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=mega_facebook

# Redis Configuration
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# MinIO Object Storage
MINIO_ROOT_USER=CHANGE_ME_ACCESS_KEY
MINIO_ROOT_PASSWORD=CHANGE_ME_SECRET_KEY_MIN_8_CHARS
MINIO_BUCKET=mega-uploads
MINIO_BROWSER=off

# Elasticsearch
ELASTIC_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# JWT Configuration
JWT_SECRET=CHANGE_ME_RANDOM_STRING_MIN_32_CHARS
JWT_ACCESS_EXPIRATION=900
JWT_REFRESH_EXPIRATION_DAYS=7

# API Configuration
API_PORT=3001

# Web Configuration
NEXT_PUBLIC_API_URL=https://yourdomain.com/api

# Nginx Ports
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# SSL Configuration (when using HTTPS)
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# Resource Limits (optional - uncomment to override defaults)
# POSTGRES_MAX_CONNECTIONS=200
# REDIS_MAX_MEMORY=256mb
# ELASTICSEARCH_HEAP_SIZE=512m

# Logging
# LOG_LEVEL=info
# LOG_FORMAT=json

# Monitoring (optional)
# ENABLE_METRICS=true
# METRICS_PORT=9090

# Backup Configuration (optional)
# BACKUP_ENABLED=true
# BACKUP_SCHEDULE="0 2 * * *"
# BACKUP_RETENTION_DAYS=30
# BACKUP_S3_BUCKET=backups
# BACKUP_S3_ENDPOINT=s3.amazonaws.com