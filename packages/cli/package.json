{
  "name": "autonow-fb",
  "version": "1.0.0",
  "description": "CLI tool for quick setup and management of AutoNow FB platform",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "autonow-fb": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "clean": "rm -rf dist",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "start": "node ./dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "test": "jest"
  },
  "keywords": [
    "cli",
    "autonow-fb",
    "setup",
    "docker",
    "monorepo",
    "social-network",
    "deployment"
  ],
  "author": "AutoNow FB Team",
  "license": "MIT",
  "homepage": "https://github.com/sherlock-126/mega_facebook#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/sherlock-126/mega_facebook.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/sherlock-126/mega_facebook/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@clack/prompts": "^0.7.0",
    "axios": "^1.6.0",
    "boxen": "^7.1.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "conf": "^13.0.0",
    "dotenv": "^16.4.0",
    "execa": "^8.0.1",
    "fs-extra": "^11.2.0",
    "ora": "^8.0.0",
    "semver": "^7.6.0",
    "tar": "^7.0.0",
    "terminal-link": "^3.0.0",
    "update-notifier": "^7.0.0",
    "which": "^4.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.14.11",
    "@types/semver": "^7.5.8",
    "@types/update-notifier": "^6.0.8",
    "@types/which": "^3.0.4",
    "jest": "^29.7.0",
    "tsx": "^4.0.0",
    "tsup": "^8.1.0",
    "typescript": "^5.5.4"
  }
}